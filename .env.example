# Nerve Hub Environment Variables

# Absolute path to the SQLite database file.
# Set this to share one DB between the compiled MCP binary and the dev server.
# Default (unset): <project-root>/.nerve/hub.db
# NERVE_DB_PATH=$HOME/.nerve/hub.db

# Public URL for webhook callbacks (used by Runner when dispatching tasks)
NERVE_PUBLIC_URL=http://localhost:3141

# API server port (default: 3141)
PORT=3141
